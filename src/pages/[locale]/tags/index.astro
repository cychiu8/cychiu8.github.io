---
import type { GetStaticPaths } from 'astro';
import TitlePage from '../../../components/TitlePage.astro';
import {
	CATEGORIES,
	LANGUAGE_INFO,
	PREFIXED_LOCALES,
	SITE_TITLE,
	withBase,
	type Language,
} from '../../../consts';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getPosts, getUsedTags } from '../../../utils/posts';

export const getStaticPaths = (() => {
	return PREFIXED_LOCALES.map((locale) => ({ params: { locale } }));
}) satisfies GetStaticPaths;

const locale = Astro.params.locale as Language;
const prefix = `/${locale}`;

const posts = await getPosts();
const tags = await getUsedTags();

const categoryCounts = CATEGORIES.map((category) => ({
	category,
	count: posts.filter((post) => post.data.category === category).length,
}));

const chipClass =
	'inline-block bg-slate-200 text-gray-700 dark:bg-slate-800 dark:text-gray-200 rounded-full px-4 py-1.5 text-sm font-semibold hover:bg-honey hover:text-forest dark:hover:bg-honey dark:hover:text-forest transition-colors';
const emptyChipClass =
	'inline-block bg-slate-200 text-gray-700 dark:bg-slate-800 dark:text-gray-200 rounded-full px-4 py-1.5 text-sm font-semibold opacity-40';
---

<BaseLayout
	title={`Tags - ${SITE_TITLE}`}
	description="Browse posts by tag or category."
	htmlLang={LANGUAGE_INFO[locale].htmlLang}
>
	<TitlePage title="Tags" />

	<div class="flex flex-col gap-8">
		<div class="flex flex-wrap gap-3">
			{
				tags.length > 0 ? (
					tags.map(({ tag, count }) => (
						<a href={withBase(`${prefix}/tags/${encodeURIComponent(tag)}/`)} class={chipClass}>
							#{tag} <span class="opacity-60">({count})</span>
						</a>
					))
				) : (
					<p class="text-gray-500">No tags yet.</p>
				)
			}
		</div>

		<div>
			<h2 class="text-2xl font-bold mb-4">Categories</h2>
			<div class="flex flex-wrap gap-3">
				{
					categoryCounts.map(({ category, count }) =>
						count > 0 ? (
							<a href={withBase(`${prefix}/category/${category}/`)} class={chipClass}>
								{category} <span class="opacity-60">({count})</span>
							</a>
						) : (
							<span class={emptyChipClass}>
								{category} <span class="opacity-60">(0)</span>
							</span>
						),
					)
				}
			</div>
		</div>
	</div>
</BaseLayout>
