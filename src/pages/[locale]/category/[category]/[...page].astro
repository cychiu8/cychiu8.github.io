---
import type { GetStaticPaths, Page } from 'astro';
import ListCategories from '../../../../components/ListCategories.astro';
import ListPosts from '../../../../components/ListPosts.astro';
import Pagination from '../../../../components/Pagination.astro';
import TitlePage from '../../../../components/TitlePage.astro';
import {
	CATEGORIES,
	LANGUAGE_INFO,
	PREFIXED_LOCALES,
	SITE_TITLE,
	type Language,
} from '../../../../consts';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getPosts, localizePosts, type Post } from '../../../../utils/posts';

export const getStaticPaths = (async ({ paginate }) => {
	const posts = await getPosts();
	const paths = await Promise.all(
		PREFIXED_LOCALES.flatMap((locale) =>
			CATEGORIES.map(async (category) =>
				paginate(
					await localizePosts(
						posts.filter((post) => post.data.category === category),
						locale,
					),
					{ params: { locale, category }, pageSize: 6 },
				),
			),
		),
	);
	return paths.flat();
}) satisfies GetStaticPaths;

interface Props {
	page: Page<Post>;
}

const locale = Astro.params.locale as Language;
const { category } = Astro.params;
const { page } = Astro.props;
---

<BaseLayout
	title={`${category} - ${SITE_TITLE}`}
	description={`Posts in the ${category} category.`}
	htmlLang={LANGUAGE_INFO[locale].htmlLang}
>
	<TitlePage title={category!} />
	<ListCategories activeCategory={category} />
	<ListPosts posts={page.data} />
	<Pagination page={page} />
</BaseLayout>
