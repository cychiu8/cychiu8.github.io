---
import { render } from 'astro:content';
import ListRelatedPosts from '../../../components/ListRelatedPosts.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import { LANGUAGE_INFO, PREFIXED_LOCALES, type Language } from '../../../consts';
import BlogPost from '../../../layouts/BlogPost.astro';
import {
	getAllPostEntries,
	getPostLocale,
	getPosts,
	getRelatedPosts,
	type Post,
} from '../../../utils/posts';

export async function getStaticPaths() {
	// One page per default post per locale, rendering the translation when it
	// exists and falling back to the default version otherwise.
	const entries = await getAllPostEntries();
	const posts = await getPosts();

	return PREFIXED_LOCALES.flatMap((locale) =>
		posts.map((post) => {
			const translation = entries.find((p) => p.id === `${post.id}/${locale}`);
			return {
				params: { locale, slug: post.id },
				props: { post: translation ?? post, basePost: post, isFallback: !translation },
			};
		}),
	);
}

interface Props {
	post: Post;
	basePost: Post;
	isFallback: boolean;
}

const locale = Astro.params.locale as Language;
const { post, basePost, isFallback } = Astro.props;

const posts = await getPosts();
const relatedPosts = getRelatedPosts(posts, basePost);

const { Content, headings, remarkPluginFrontmatter } = await render(post);
---

<BlogPost
	data={post.data}
	locale={isFallback ? getPostLocale(post) : locale}
	readTime={remarkPluginFrontmatter.minutesRead}
	untranslatedNote={isFallback ? LANGUAGE_INFO[locale].untranslatedNote : undefined}
	searchable={!isFallback}
>
	<div class="grid grid-cols-1 md:grid-cols-[20%_auto] gap-10 mt-8">
		<!-- table of contents -->
		<aside class="md:flex flex-col gap-8 hidden">
			<div class="sticky top-24 self-start hidden md:block transition-all duration-200">
				{headings && headings.length > 0 && <TableOfContents headings={headings} />}
			</div>
		</aside>

		<!-- post body -->
		<article class="max-w-full w-full">
			<div class="prose prose-lg md:prose-xl dark:prose-invert mb-12 min-w-full">
				<Content />
			</div>

			<!-- related posts -->
			<footer>
				<h2 class="font-bold text-lg dark:text-white mb-6">Related Posts</h2>
				<ListRelatedPosts posts={relatedPosts} />
			</footer>
		</article>
	</div>
</BlogPost>

<script>
	// Highlight the clicked table-of-contents entry.
	const links = document.querySelectorAll<HTMLAnchorElement>('aside nav a[href^="#"]');
	const active = ['text-indigo-600', 'dark:text-indigo-400', 'font-bold'];
	const inactive = ['text-gray-600', 'dark:text-gray-400'];

	links.forEach((link) => {
		link.addEventListener('click', () => {
			links.forEach((other) => {
				other.classList.remove(...active);
				other.classList.add(...inactive);
			});
			link.classList.remove(...inactive);
			link.classList.add(...active);
		});
	});
</script>
