---
import { getEntry, render } from 'astro:content';
import TitlePage from '../components/TitlePage.astro';
import { SITE_TITLE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';

// Page text lives in src/content/pages/about.md — edit it there.
const about = await getEntry('pages', 'about');
if (!about) throw new Error('Missing content file: src/content/pages/about.md');
const { Content } = await render(about);
const title = about.data.title ?? 'About';
---

<BaseLayout title={`${title} - ${SITE_TITLE}`} description={about.data.description}>
	<TitlePage title={title} />

	<div class="prose prose-lg dark:prose-invert max-w-2xl">
		<Content />
	</div>
</BaseLayout>
