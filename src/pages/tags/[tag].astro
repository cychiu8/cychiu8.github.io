---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, LANGUAGES, LANGUAGE_INFO, SITE_TITLE, withBase } from '../../consts';

export async function getStaticPaths() {
	// One page per category tag and per language tag.
	return [...CATEGORIES, ...LANGUAGES].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;

const isLanguage = (LANGUAGES as readonly string[]).includes(tag);
const heading = isLanguage ? LANGUAGE_INFO[tag as keyof typeof LANGUAGE_INFO].label : `#${tag}`;

const posts = (await getCollection('blog'))
	.filter((post) => (isLanguage ? post.data.lang === tag : (post.data.tags as string[]).includes(tag)))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${heading} - ${SITE_TITLE}`} description={`Posts tagged ${heading}.`} />
		<style>
			ul {
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				margin-bottom: 1em;
			}
			ul li a {
				text-decoration: none;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover .title,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>{heading}</h1>
			{posts.length === 0 && <p>No posts yet.</p>}
			<ul>
				{
					posts.map((post) => (
						<li>
							<a href={withBase(`/blog/${post.id}/`)}>
								<h4 class="title">{post.data.title}</h4>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						</li>
					))
				}
			</ul>
			<p><a href={withBase('/tags/')}>← All tags</a></p>
		</main>
		<Footer />
	</body>
</html>
