---
import type { GetStaticPaths, Page } from 'astro';
import ListPosts from '../../../components/ListPosts.astro';
import Pagination from '../../../components/Pagination.astro';
import TitlePage from '../../../components/TitlePage.astro';
import { LANGUAGES, LANGUAGE_INFO, SITE_TITLE, type Language } from '../../../consts';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getPosts, type Post } from '../../../utils/posts';

export const getStaticPaths = (async ({ paginate }) => {
	const posts = await getPosts();

	return LANGUAGES.flatMap((lang) => {
		const filtered = posts.filter((post) => post.data.lang === lang);
		return paginate(filtered, { params: { lang }, pageSize: 6 });
	});
}) satisfies GetStaticPaths;

interface Props {
	page: Page<Post>;
}

const { lang } = Astro.params;
const { page } = Astro.props;
const label = LANGUAGE_INFO[lang as Language].label;
---

<BaseLayout title={`${label} - ${SITE_TITLE}`} description={`Posts written in ${label}.`}>
	<TitlePage title={label} />
	<ListPosts posts={page.data} />
	<Pagination page={page} />
</BaseLayout>
