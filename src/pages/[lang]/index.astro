---
import type { GetStaticPaths } from 'astro';
import ListCategories from '../../components/ListCategories.astro';
import ListPosts from '../../components/ListPosts.astro';
import TitlePage from '../../components/TitlePage.astro';
import { LANGUAGE_INFO, SITE_TITLE, type Language } from '../../consts';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getUsedLanguages, getPosts } from '../../utils/posts';

export const getStaticPaths = (async () => {
	const languages = await getUsedLanguages();
	return languages.map((lang) => ({ params: { lang } }));
}) satisfies GetStaticPaths;

const lang = Astro.params.lang as Language;
const { label, htmlLang } = LANGUAGE_INFO[lang];

const MAX_POSTS = 5;
const posts = await getPosts(MAX_POSTS, lang);
---

<BaseLayout
	title={`${SITE_TITLE} (${label})`}
	description={`Posts written in ${label}.`}
	htmlLang={htmlLang}
>
	<div class="flex flex-col gap-4">
		<TitlePage title={SITE_TITLE} />
		<p class="text-gray-700 dark:text-gray-300 max-w-2xl">
			Browsing posts written in <strong>{label}</strong>.
		</p>
	</div>

	<ListCategories lang={lang} />

	<div>
		<h2 class="text-lg font-medium tracking-wide text-end">Latest Posts</h2>
		<ListPosts firstBig={true} posts={posts} />
	</div>
</BaseLayout>
