---
import type { GetStaticPaths, Page } from 'astro';
import ListCategories from '../../../components/ListCategories.astro';
import ListPosts from '../../../components/ListPosts.astro';
import Pagination from '../../../components/Pagination.astro';
import TitlePage from '../../../components/TitlePage.astro';
import { LANGUAGE_INFO, SITE_TITLE, type Language } from '../../../consts';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getUsedLanguages, getPosts, type Post } from '../../../utils/posts';

export const getStaticPaths = (async ({ paginate }) => {
	const languages = await getUsedLanguages();
	return await Promise.all(
		languages.map(async (lang) => {
			const posts = await getPosts(undefined, lang);
			return paginate(posts, { params: { lang }, pageSize: 6 });
		}),
	).then((pages) => pages.flat());
}) satisfies GetStaticPaths;

interface Props {
	page: Page<Post>;
}

const lang = Astro.params.lang as Language;
const { label, htmlLang } = LANGUAGE_INFO[lang];
const { page } = Astro.props;
---

<BaseLayout
	title={`Blog (${label}) - ${SITE_TITLE}`}
	description={`All posts written in ${label}.`}
	htmlLang={htmlLang}
>
	<TitlePage title={`All Posts (${label})`} />
	<ListCategories lang={lang} />
	<ListPosts posts={page.data} />
	<Pagination page={page} />
</BaseLayout>
