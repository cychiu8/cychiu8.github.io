---
import { withBase } from '../consts';

interface Props {
	tag: string;
	label?: string;
}

const { tag, label = tag } = Astro.props;
---

<a href={withBase(`/tags/${encodeURIComponent(tag)}/`)} aria-label={label}>
	<span
		class="bg-indigo-600 font-semibold text-white dark:bg-indigo-900 shadow text-sm w-fit px-2 py-1 md:px-5 md:py-2 rounded-full"
	>
		{label}
	</span>
</a>
