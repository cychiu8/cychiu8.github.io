---
import { localePrefix, withBase } from '../consts';

interface Props {
	tag: string;
	label?: string;
	// Root-relative link target (without locale prefix); defaults to the tag page.
	href?: string;
}

const { tag, label = tag, href = `/tags/${encodeURIComponent(tag)}/` } = Astro.props;
const prefix = localePrefix(Astro.url.pathname);
---

<a href={withBase(`${prefix}${href}`)} aria-label={label}>
	<span
		class="bg-indigo-600 font-semibold text-white dark:bg-indigo-900 shadow text-sm w-fit px-2 py-1 md:px-5 md:py-2 rounded-full"
	>
		{label}
	</span>
</a>
