---
import type { HTMLAttributes } from 'astro/types';
import { withBase } from '../consts';

type Props = HTMLAttributes<'a'>;

// `href` is a root-relative path like "/blog" or "/zh-tw/blog";
// the base prefix is added on render.
const { href, class: className, ...props } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';
const target = String(href).replace(/\/$/, '') || '/';
const isActive = pathname === target || pathname.startsWith(`${target}/`);
---

<a
	href={withBase(String(href))}
	class:list={[
		'hover:underline underline-offset-4',
		{ 'underline font-bold': isActive },
		className,
	]}
	{...props}
>
	<slot />
</a>
