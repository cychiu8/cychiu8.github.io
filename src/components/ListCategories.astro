---
import { localePrefix, withBase } from '../consts';
import { getUsedCategories } from '../utils/posts';

interface Props {
	activeCategory?: string;
}

const { activeCategory } = Astro.props;
const categories = await getUsedCategories();
const prefix = localePrefix(Astro.url.pathname);

const chipClass = (isActive: boolean) =>
	[
		'pb-2.5 first-letter:uppercase font-medium border-b-2 transition-colors duration-150 ease-linear z-10',
		isActive
			? 'border-leaf dark:border-honey text-black dark:text-white'
			: 'border-transparent text-gray-600 hover:text-gray-800 hover:border-leaf dark:text-gray-300 dark:hover:text-white dark:hover:border-honey',
	].join(' ');
---

<div class="relative flex flex-wrap min-w-full gap-5">
	<a href={withBase(`${prefix}/blog/`)} class={chipClass(activeCategory === undefined)}>View All</a>
	{
		categories.map((category) => (
			<a href={withBase(`${prefix}/category/${category}/`)} class={chipClass(activeCategory === category)}>
				{category}
			</a>
		))
	}

	<div class="hidden sm:block absolute w-full bottom-0 border-b-2 border-stone-200 -z-40 dark:border-gray-600"></div>
</div>
