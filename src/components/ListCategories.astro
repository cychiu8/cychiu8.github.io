---
import { withBase, type Language } from '../consts';
import { getUsedCategories } from '../utils/posts';

interface Props {
	activeCategory?: string;
	// When set, chips link inside the language section and only show
	// categories with posts in that language.
	lang?: Language;
}

const { activeCategory, lang } = Astro.props;
const categories = await getUsedCategories(lang);
const prefix = lang ? `/${lang}` : '';

const chipClass = (isActive: boolean) =>
	[
		'pb-2.5 first-letter:uppercase font-medium border-b-2 transition-colors duration-150 ease-linear z-10',
		isActive
			? 'border-black text-black dark:border-white dark:text-white'
			: 'border-transparent text-gray-600 hover:text-gray-800 hover:border-black dark:text-gray-300 dark:hover:text-white dark:hover:border-white',
	].join(' ');
---

<div class="relative flex flex-wrap min-w-full gap-5">
	<a href={withBase(`${prefix}/blog/`)} class={chipClass(activeCategory === undefined)}>View All</a>
	{
		categories.map((category) => (
			<a
				href={withBase(`${prefix}/category/${category}/`)}
				class={chipClass(activeCategory === category)}
			>
				{category}
			</a>
		))
	}

	<div class="hidden sm:block absolute w-full bottom-0 border-b-2 border-stone-200 -z-40 dark:border-gray-600"></div>
</div>
