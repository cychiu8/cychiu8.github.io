---
import { LANGUAGES, LANGUAGE_INFO, withBase, type Language } from '../consts';
import { getUsedLanguages } from '../utils/posts';

// The language section is the first path segment after the base, e.g. /en/blog/.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname.replace(base, '');
const firstSegment = pathname.split('/').filter(Boolean)[0];
const current = (LANGUAGES as readonly string[]).includes(firstSegment)
	? (firstSegment as Language)
	: undefined;

const usedLanguages = await getUsedLanguages();
---

<div class="flex items-center gap-3 text-sm">
	<a
		href={withBase('/')}
		class:list={[
			'hover:underline underline-offset-4',
			current === undefined ? 'font-bold underline' : 'text-gray-600 dark:text-gray-400',
		]}
	>
		All
	</a>
	{
		LANGUAGES.map((lang) =>
			usedLanguages.includes(lang) ? (
				<a
					href={withBase(`/${lang}/`)}
					class:list={[
						'hover:underline underline-offset-4',
						current === lang ? 'font-bold underline' : 'text-gray-600 dark:text-gray-400',
					]}
				>
					{LANGUAGE_INFO[lang].label}
				</a>
			) : (
				<span class="text-gray-400 dark:text-gray-600 cursor-default" title="No posts yet">
					{LANGUAGE_INFO[lang].label}
				</span>
			),
		)
	}
</div>
