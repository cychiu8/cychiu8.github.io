---
import { SITE_TITLE, localePrefix, withBase } from '../consts';
import HeaderLink from './HeaderLink.astro';
import Icon from './icons/Icon.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import Search from './Search.astro';
import ToggleTheme from './ToggleTheme.astro';

// Navigation stays inside the current locale section, if any.
const prefix = localePrefix(Astro.url.pathname);
---

<header class="relative flex items-center h-12 font-semibold">
	<a class="text-lg mr-auto" href={withBase(prefix || '/')}>{SITE_TITLE}</a>

	<div
		id="header-drawer"
		class="shadow rounded-l-lg md:bg-transparent dark:md:bg-transparent bg-paper dark:bg-night md:shadow-none md:rounded-none md:border-none md:h-auto md:static absolute transition-transform duration-300 ease-in translate-x-96 md:translate-x-0 top-12 -right-5 pl-4 pt-6 pb-4 md:p-0 h-80 w-56 md:h-auto md:w-auto z-50"
	>
		<nav class="flex h-full flex-col justify-between gap-12 text-left md:flex-row md:w-full md:gap-5">
			<div
				class="flex flex-col gap-4 md:flex-row md:border-r-2 border-black pr-4 dark:border-white"
			>
				<HeaderLink href={`${prefix}/blog`} class="text-2xl md:text-base">Blog</HeaderLink>
				<HeaderLink href={`${prefix}/tags`} class="flex items-center gap-1 text-2xl md:text-base">
					<Icon name="tag" size={16} /> Tags
				</HeaderLink>
				<HeaderLink href={`${prefix}/about`} class="text-2xl md:text-base">About</HeaderLink>
			</div>

			<div class="flex flex-col md:flex-row justify-center items-center md:justify-end gap-4 md:gap-5 md:p-0">
				<LanguageSwitcher />
				<a
					href="https://github.com/cychiu8"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="GitHub"
				>
					<Icon name="github" size={20} />
				</a>
			</div>
		</nav>
	</div>

	<div class="flex items-center gap-3 md:pl-3">
		<Search />
		<ToggleTheme />
		<button id="header-drawer-button" type="button" class="md:ml-6 md:hidden cursor-pointer">
			<Icon name="menu" />
			<span class="sr-only">Show menu</span>
		</button>
	</div>
</header>

<script>
	document.addEventListener('click', (event) => {
		const menu = document.getElementById('header-drawer');
		const menuButton = document.getElementById('header-drawer-button');

		if (menuButton?.contains(event.target as Node)) {
			menu?.classList.toggle('translate-x-96');
		} else if (!menu?.contains(event.target as Node)) {
			menu?.classList.add('translate-x-96');
		}
	});
</script>
