---
import type { TocEntry } from './TableOfContents.astro';

interface Props {
	heading: TocEntry;
}

const { heading } = Astro.props;
---

<li class="flex flex-col">
	<a
		href={'#' + heading.slug}
		class="text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 py-1 mb-1 first-letter:uppercase w-fit line-clamp-2 transition-colors duration-200"
	>
		{heading.text}
	</a>
	{
		heading.subheadings.length > 0 && (
			<ul class="ml-3">
				{heading.subheadings.map((subheading) => (
					<Astro.self heading={subheading} />
				))}
			</ul>
		)
	}
</li>
