---
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description?: string;
	image?: ImageMetadata;
	articleDate?: string;
	htmlLang?: string;
}

import { SITE_DESCRIPTION } from '../consts';

const { title, description = SITE_DESCRIPTION, image, htmlLang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
	<head>
		<BaseHead title={title} description={description} image={image} />
		<!-- Set the theme before first paint to avoid a flash of the wrong theme. -->
		<script is:inline>
			(function () {
				const stored = typeof localStorage !== 'undefined' && localStorage.getItem('theme');
				const theme =
					stored ||
					(window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
				document.documentElement.classList.toggle('dark', theme === 'dark');
			})();
		</script>
	</head>

	<body class="bg-paper text-stone-950 dark:bg-night dark:text-white antialiased">
		<main
			class="px-5 sm:mx-auto sm:max-w-2xl sm:px-8 lg:px-0 md:max-w-6xl grid gap-12 mt-4 overflow-hidden md:overflow-visible min-h-screen content-start"
		>
			<Header />
			<slot />
			<Footer />
		</main>
		<style>
			body {
				margin-left: calc(100vw - 100%); /* prevent layout shift from the scrollbar */
			}
		</style>
	</body>
</html>
