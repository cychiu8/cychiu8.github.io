---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Tag from '../components/Tag.astro';
import { LANGUAGE_INFO, type Language } from '../consts';
import BaseLayout from './BaseLayout.astro';

interface Props {
	data: CollectionEntry<'blog'>['data'];
	locale: Language;
	readTime?: string;
	// Shown when a locale page falls back to the default-language content.
	untranslatedNote?: string;
	// Fallback pages are excluded from the search index to avoid duplicates.
	searchable?: boolean;
}

const { data, locale, readTime, untranslatedNote, searchable = true } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, category, tags } = data;
---

<BaseLayout
	title={title}
	description={description}
	image={heroImage}
	articleDate={pubDate.toISOString()}
	htmlLang={LANGUAGE_INFO[locale].htmlLang}
>
	<article
		class="min-w-full md:py-4 sm:max-w-none md:max-w-none"
		data-pagefind-body={searchable || undefined}
	>
		<header class="mb-3 flex flex-col justify-center items-center gap-6">
			<div class="flex flex-col gap-2">
				<div
					class="flex flex-wrap items-center justify-center gap-x-2 text-sm text-gray-600 dark:text-gray-400"
				>
					<span>Published <FormattedDate date={pubDate} /></span>
					{readTime && <span class="font-bold">- {readTime}</span>}
					{
						updatedDate && (
							<span class="italic">
								(Updated <FormattedDate date={updatedDate} />)
							</span>
						)
					}
				</div>
				<h1 class="text-center text-4xl md:text-6xl md:pb-2.5 font-semibold">
					{title}
				</h1>
			</div>

			<div class="flex flex-wrap justify-center items-center gap-2 gap-y-4 md:gap-5">
				<Tag tag={category} href={`/category/${category}/`} />
				{tags.map((tag) => <Tag tag={tag} label={`#${tag}`} />)}
			</div>

			{
				untranslatedNote && (
					<p class="text-sm italic text-gray-500 dark:text-gray-400">{untranslatedNote}</p>
				)
			}
		</header>

		{
			heroImage && (
				<Image
					src={heroImage}
					width={1000}
					height={500}
					quality={100}
					loading="eager"
					class="rounded-md w-full max-h-[300px] md:max-h-[500px] my-8 object-cover"
					alt={`Cover image for ${title}`}
				/>
			)
		}

		<hr class="border-stone-200 dark:border-gray-700" />

		<slot />
	</article>
</BaseLayout>
